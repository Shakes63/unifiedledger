{
  "name": "unifiedledger",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-start.mjs",
    "build": "BROWSERSLIST_IGNORE_OLD_DATA=true BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "db:init": "node scripts/init-db.js",
    "db:studio": "drizzle-kit studio",
    "db:generate:sqlite": "drizzle-kit generate --config drizzle.config.sqlite.ts",
    "db:bootstrap:sqlite": "node scripts/bootstrap-sqlite-migrations.mjs",
    "db:migrate:sqlite": "drizzle-kit migrate --config drizzle.config.sqlite.ts",
    "db:migrate:sqlite:safe": "pnpm -s db:bootstrap:sqlite && pnpm -s db:migrate:sqlite",
    "db:verify:money": "node scripts/verify-money-integrity.mjs",
    "db:verify:migrations": "node scripts/verify-migrations.mjs",
    "db:reconcile:credit": "node scripts/reconcile-credit-balances.mjs",
    "release:patch": "npm version patch -m \"release: v%s\" && git push origin main --follow-tags",
    "release:minor": "npm version minor -m \"release: v%s\" && git push origin main --follow-tags",
    "release:major": "npm version major -m \"release: v%s\" && git push origin main --follow-tags",
    "db:migrate:sqlite:verify": "pnpm -s db:migrate:sqlite:safe && pnpm -s db:verify:money",
    "generate-test-data": "tsx scripts/generate-test-data.ts"
  },
  "dependencies": {
    "@better-fetch/fetch": "1.3.1",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@react-email/components": "^1.0.12",
    "@serwist/next": "^9.5.11",
    "@tanstack/react-virtual": "^3.14.5",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/ua-parser-js": "^0.7.39",
    "better-auth": "^1.6.23",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "^0.45.2",
    "fastest-levenshtein": "^1.0.16",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.553.0",
    "nanoid": "^5.1.16",
    "next": "16.2.10",
    "nodemailer": "^7.0.11",
    "papaparse": "^5.5.4",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-email": "^5.0.6",
    "react-hook-form": "^7.81.0",
    "recharts": "^3.9.2",
    "resend": "^6.17.2",
    "server-only": "^0.0.1",
    "serwist": "^9.5.11",
    "sonner": "^2.0.7",
    "speakeasy": "^2.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "ua-parser-js": "^2.0.10",
    "uuid": "^13.0.0",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.26",
    "@types/nodemailer": "^7.0.4",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react": "^5.1.2",
    "baseline-browser-mapping": "^2.10.42",
    "bcryptjs": "^3.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^27.3.0",
    "prettier": "^3.9.5",
    "qrcode.react": "^4.2.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "webpack": "^5.108.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "core-js",
      "esbuild",
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "@clerk/shared",
      "unrs-resolver"
    ]
  }
}
